{
  "name": "whatsapp-manager",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "prisma generate && next build && esbuild server.ts --bundle --platform=node --outfile=dist/server.js --external:next --external:express --external:socket.io --external:bcryptjs --external:jsonwebtoken --external:cookie-parser --external:cookie --external:@prisma/client --external:pino",
    "start": "node dist/server.js",
    "lint": "next lint",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@prisma/client": "^6.2.1",
    "@whiskeysockets/baileys": "^6.7.9",
    "axios": "^1.14.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "cookie": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "esbuild": "^0.27.4",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.454.0",
    "motion": "^11.11.11",
    "next": "15.0.2",
    "pino": "^9.5.0",
    "prisma": "^6.2.1",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^2.5.4",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.17.6",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-config-next": "15.0.2",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3"
  }
}
