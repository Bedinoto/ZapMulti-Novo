// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id              String   @id // This will be the JID
  name            String
  phoneNumber     String?
  lastInteraction DateTime @default(now())
  source          String   @default("automatic") // "automatic" or "manual"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  messages        Message[]
  chats           Chat[]
}

model Chat {
  id            String   @id // sessionId--jid
  sessionId     String
  jid           String
  name          String?
  unreadCount   Int      @default(0)
  timestamp     DateTime @default(now())
  contact       Contact  @relation(fields: [jid], references: [id])
  messages      Message[]

  @@unique([sessionId, jid])
}

model Message {
  id               String   @id // message key id
  chatId           String
  jid              String
  fromMe           Boolean
  text             String?
  type             String   @default("text")
  timestamp        DateTime @default(now())
  messageTimestamp Int
  status           Int      @default(0)
  mediaUrl         String?
  
  chat             Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  contact          Contact  @relation(fields: [jid], references: [id], onDelete: Cascade)

  @@index([jid])
  @@index([chatId])
}
